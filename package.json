		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16"
	},
	"dependencies": {
		"@lucide/svelte": "^1.23.0",
		"@supabase/ssr": "^0.12.0",
		"@supabase/supabase-js": "^2.110.0",
		"lucide-svelte": "^1.0.1"
	}
